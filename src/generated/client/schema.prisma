// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String               @id @default(cuid())
  name          String?
  email         String?              @unique
  emailVerified DateTime?
  image         String?
  password      String? // Hashed password for credentials auth
  goal          String? // Added for onboarding
  activityLevel String? // Added for onboarding
  recentLogs    String? // Added for onboarding
  accounts      Account[]
  sessions      Session[]
  restrictions  DietaryRestriction[]
  foods         AvailableFood[]
  foodLogs      FoodLog[] // NEW: Relation to consumption history
  preferences   UserPreferences?
}

// ... (previous models remains same)

model FoodLog {
  id         String   @id @default(cuid())
  userId     String
  name       String
  calories   Int?
  proteins   Float?
  fats       Float?
  carbs      Float?
  mealType   String // desayuno, almuerzo, cena, snack
  imageEmoji String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserPreferences {
  id            String   @id @default(cuid())
  userId        String   @unique
  onboarding    Boolean  @default(false)
  theme         String   @default("light")
  notifications Boolean  @default(true)
  avatar        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// App Models
model DietaryRestriction {
  id        String   @id @default(cuid())
  userId    String?
  foodItem  String
  reason    String
  severity  String
  category  String? // NEW: AI-generated category
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AvailableFood {
  id        String   @id @default(cuid())
  userId    String?
  name      String
  category  String?
  mealType  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MealSuggestion {
  id              String   @id @default(cuid())
  userId          String?
  mealType        String
  suggestion      String
  explanation     String?
  compatibleFoods String?
  createdAt       DateTime @default(now())
}

// Preloaded food suggestions for common restrictions
model PreloadedSuggestion {
  id          String   @id @default(cuid())
  name        String
  description String
  ingredients String // JSON array
  mealType    String
  tags        String? // JSON array: vegetarian, gluten-free, etc.
  calories    Int?
  prepTime    Int? // minutes
  imageUrl    String?
  createdAt   DateTime @default(now())
}
